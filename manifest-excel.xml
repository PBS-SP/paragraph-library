<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- ═══════════════════════════════════════════════
       PBS Excel Tools — Excel Add-in
       Manifest version: 1.0.0
       Taskpane: https://pbs-sp.github.io/paragraph-library/taskpane-excel.html
       Hosted:   https://pbs-sp.github.io/paragraph-library/manifest-excel.xml
       ═══════════════════════════════════════════════ -->

  <Id>b2c3d4e5-f6a7-8901-bcde-f12345678901</Id>
  <Version>1.0.0</Version>
  <ProviderName>Prescott Business Solutions</ProviderName>
  <DefaultLocale>en-AU</DefaultLocale>

  <DisplayName DefaultValue="PBS Excel Tools"/>
  <Description DefaultValue="Formatting tools, templates and AI-powered assistance for Excel — built for Prescott Business Solutions."/>

  <IconUrl DefaultValue="https://pbs-sp.github.io/paragraph-library/assets/icon-80.png"/>
  <HighResolutionIconUrl DefaultValue="https://pbs-sp.github.io/paragraph-library/assets/icon-128.png"/>

  <SupportUrl DefaultValue="https://prescottsolutions.sharepoint.com/sites/PrescottBusinessSolutions"/>

  <AppDomains>
    <AppDomain>pbs-sp.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="ExcelApi" MinVersion="1.9"/>
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://pbs-sp.github.io/paragraph-library/taskpane-excel.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>

          <!-- ── Function file (required for ribbon buttons without task pane) ── -->
          <FunctionFile resid="FunctionFile.Url"/>

          <!-- ── Ribbon: Home tab, PBS Tools group ── -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="PBSToolsGroup">
                <Label resid="PBSGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>

                <!-- Open task pane button -->
                <Control xsi:type="Button" id="OpenTaskPane">
                  <Label resid="OpenPane.Label"/>
                  <Supertip>
                    <Title resid="OpenPane.Label"/>
                    <Description resid="OpenPane.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>PBSExcelTools</TaskpaneId>
                    <SourceLocation resid="TaskPane.Url"/>
                  </Action>
                </Control>

                <!-- Format Numbers -->
                <Control xsi:type="Button" id="BtnFormatNumbers">
                  <Label resid="FormatNumbers.Label"/>
                  <Supertip>
                    <Title resid="FormatNumbers.Label"/>
                    <Description resid="FormatNumbers.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>ribbonFormatNumbers</FunctionName>
                  </Action>
                </Control>

                <!-- Format not Zero -->
                <Control xsi:type="Button" id="BtnFormatNotZero">
                  <Label resid="FormatNotZero.Label"/>
                  <Supertip>
                    <Title resid="FormatNotZero.Label"/>
                    <Description resid="FormatNotZero.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>ribbonFormatNotZero</FunctionName>
                  </Action>
                </Control>

                <!-- PivReformat -->
                <Control xsi:type="Button" id="BtnPivReformat">
                  <Label resid="PivReformat.Label"/>
                  <Supertip>
                    <Title resid="PivReformat.Label"/>
                    <Description resid="PivReformat.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>ribbonPivReformat</FunctionName>
                  </Action>
                </Control>

                <!-- Format Pivot Numbers -->
                <Control xsi:type="Button" id="BtnFormatPivotNumbers">
                  <Label resid="FormatPivotNumbers.Label"/>
                  <Supertip>
                    <Title resid="FormatPivotNumbers.Label"/>
                    <Description resid="FormatPivotNumbers.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>ribbonFormatPivotNumbers</FunctionName>
                  </Action>
                </Control>

                <!-- Unhide All Sheets -->
                <Control xsi:type="Button" id="BtnUnhideSheets">
                  <Label resid="UnhideSheets.Label"/>
                  <Supertip>
                    <Title resid="UnhideSheets.Label"/>
                    <Description resid="UnhideSheets.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>ribbonUnhideSheets</FunctionName>
                  </Action>
                </Control>

                <!-- Reset Styles — intentionally NOT a ribbon button (destructive, needs confirm dialog in task pane) -->

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://pbs-sp.github.io/paragraph-library/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://pbs-sp.github.io/paragraph-library/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://pbs-sp.github.io/paragraph-library/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="TaskPane.Url" DefaultValue="https://pbs-sp.github.io/paragraph-library/taskpane-excel.html"/>
        <bt:Url id="FunctionFile.Url" DefaultValue="https://pbs-sp.github.io/paragraph-library/commands-excel.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="PBSGroup.Label"         DefaultValue="PBS Tools"/>
        <bt:String id="OpenPane.Label"         DefaultValue="Excel Tools"/>
        <bt:String id="FormatNumbers.Label"    DefaultValue="Format (#,##)"/>
        <bt:String id="FormatNotZero.Label"    DefaultValue="Flag not Zero"/>
        <bt:String id="PivReformat.Label"      DefaultValue="PivReformat"/>
        <bt:String id="FormatPivotNumbers.Label" DefaultValue="Piv Format (#)"/>
        <bt:String id="UnhideSheets.Label"     DefaultValue="Unhide Sheets"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="OpenPane.Tooltip"            DefaultValue="Open the PBS Excel Tools task pane — formatting, templates and more."/>
        <bt:String id="FormatNumbers.Tooltip"       DefaultValue="Apply #,##0 format with red brackets for negative numbers to the selected range."/>
        <bt:String id="FormatNotZero.Tooltip"       DefaultValue="Apply green cell style and red conditional format to selected cells if value is not zero."/>
        <bt:String id="PivReformat.Tooltip"         DefaultValue="Reformat the active pivot table to tabular layout with no subtotals and repeated item labels."/>
        <bt:String id="FormatPivotNumbers.Tooltip"  DefaultValue="Apply #,##0 bracket number format to all value fields in the active pivot table."/>
        <bt:String id="UnhideSheets.Tooltip"        DefaultValue="Make all hidden sheets in the active workbook visible."/>
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>

</OfficeApp>
